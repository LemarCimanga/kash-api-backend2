# ==================== BASE DE DONNÉES ====================
DATABASE_URL=postgresql+asyncpg://neondb_owner:npg_x8iSFQ6kvtOr@ep-cold-night-atp3gryj.c-9.us-east-1.aws.neon.tech:5432/neondb?sslmode=require

# ==================== SÉCURITÉ ====================
SECRET_KEY=9a3f2d8e4c7b6a1e5f0d8c7b6a5e4d3c2b1a0f9e8d7c6b5a4f3e2d1c0b9a8f7e
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30
TOKEN_ISSUER=kash_app
TOKEN_AUDIENCE=api

# ==================== CONFIGURATION DU POOL DE CONNEXIONS ====================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
DB_ECHO=false
DB_STATEMENT_TIMEOUT=30
LOG_SLOW_QUERIES=true
SLOW_QUERY_THRESHOLD=1.0

# ==================== SÉCURITÉ DES MOTS DE PASSE ====================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_SPECIAL=true
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ==================== APPLICATION ====================
APP_NAME=Kash Application
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ==================== CORS ====================
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:5173"]
ALLOWED_HOSTS=["*"]

# ==================== CACHE REDIS ====================
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_TTL=300

# ==================== EMAIL (OPTIONNEL) ====================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=votre_email@gmail.com
# EMAIL_PASSWORD=votre_mot_de_passe
# EMAIL_FROM=noreply@kash.com
# EMAIL_USE_TLS=true

# ==================== FICHIERS ET STOCKAGE ====================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=[".jpg", ".jpeg", ".png", ".gif"]

# ==================== RATE LIMITING ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - [%(request_id)s] - [%(user_id)s] - %(message)s

# ==================== API ====================
API_V1_STR=/api/v1

# ==================== SESSION ====================
SESSION_SECRET_KEY=session_secret_key_32_chars_long_enough_here

# ==================== MONITORING (OPTIONNEL) ====================
# SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.sentry.io/1234567
# PROMETHEUS_ENABLED=false

# ==================== FEATURES FLAGS ====================
ENABLE_2FA=false
ENABLE_EMAIL_VERIFICATION=false
ENABLE_SMS_VERIFICATION=false